    "dotenv": "^16.4.5",
    "electron-log": "^5.1.1",
    "lucide-react": "^0.344.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.25",
    "@types/react": "^18.2.64",
