# 多阶段 Docker 构建配置（开发环境）
FROM node:20-alpine AS development

# 安装构建工具和运行时依赖
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    chromium

WORKDIR /app

# 复制 package 文件
COPY package*.json ./

# 安装依赖
RUN npm install

# 复制源代码
COPY . .

# 暴露开发端口
EXPOSE 9222

# 启动开发服务器
CMD ["npm", "run", "dev"]
